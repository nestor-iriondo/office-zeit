generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Person {
  name  String @id
  color String
}

model Presence {
  id        Int      @id @default(autoincrement())
  person    String
  date      String
  withDog   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([person, date])
}
